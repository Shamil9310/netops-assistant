# Пример конфига для локальной разработки.
# Скопируй нужный файл под своё окружение:
#   cp .env.development .env    — для локальной разработки
#   cp .env.test .env           — для тестового окружения
#   cp .env.production .env     — для production (обязательно заменить все CHANGE_ME)

NETOPS_ASSISTANT_APP_NAME=NetOps Assistant API
NETOPS_ASSISTANT_ENVIRONMENT=development
NETOPS_ASSISTANT_DATABASE_URL=postgresql+asyncpg://netops:netops@localhost:5432/netops_assistant
NETOPS_ASSISTANT_SECRET_KEY=dev-only-change-me
NETOPS_ASSISTANT_CORS_ORIGINS=["http://localhost:3000"]
NETOPS_ASSISTANT_SESSION_COOKIE_NAME=netops_session
NETOPS_ASSISTANT_SESSION_TTL_HOURS=12
NETOPS_ASSISTANT_SESSION_COOKIE_SECURE=false
NETOPS_ASSISTANT_BOOTSTRAP_USERNAME=engineer
NETOPS_ASSISTANT_BOOTSTRAP_PASSWORD=engineer123
NETOPS_ASSISTANT_BOOTSTRAP_FULL_NAME=Шамиль Исаев

# Пример конфига для локальной разработки.
# Скопируй нужный файл под своё окружение:
#   cp .env.development .env.local    — для локальной разработки
#   cp .env.test .env.local           — для тестового окружения
#   cp .env.production .env.local     — для production (обязательно заменить все CHANGE_ME)

# URL для браузерных запросов (должен быть доступен с машины пользователя)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# URL для SSR-запросов изнутри контейнера/сервера
INTERNAL_API_BASE_URL=http://localhost:8000
